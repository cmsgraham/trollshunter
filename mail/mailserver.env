# ============================================
# docker-mailserver environment configuration
# ============================================

# --- General ---
OVERRIDE_HOSTNAME=mail.trollshunter.com
LOG_LEVEL=info
SUPERVISOR_LOGLEVEL=warn

# --- TLS ---
SSL_TYPE=letsencrypt
TLS_LEVEL=modern

# --- Authentication ---
# SMTP auth required for sending
SPOOF_PROTECTION=1
ENABLE_SRS=1

# --- Anti-spam ---
ENABLE_RSPAMD=1
ENABLE_OPENDKIM=0
ENABLE_OPENDMARC=0
RSPAMD_LEARN=1
RSPAMD_GREYLISTING=1
ENABLE_AMAVIS=0
ENABLE_SPAMASSASSIN=0

# DKIM via Rspamd
RSPAMD_HFILTER=1
RSPAMD_HFILTER_HOSTNAME_UNKNOWN_SCORE=6

# --- Postscreen & anti-abuse ---
ENABLE_POSTFIX_VIRTUAL_TRANSPORT=0
POSTSCREEN_ACTION=enforce
ENABLE_FAIL2BAN=1
FAIL2BAN_BLOCKTYPE=drop

# --- Dovecot IMAP ---
ENABLE_IMAP=1
ENABLE_POP3=0

# --- Rate limiting ---
POSTFIX_MESSAGE_SIZE_LIMIT=26214400
ENABLE_QUOTAS=1
POSTFIX_MAILBOX_SIZE_LIMIT=0

# --- Misc ---
ENABLE_MANAGESIEVE=0
ENABLE_UPDATE_CHECK=1
ENABLE_CLAMAV=0
ONE_DIR=1
MOVE_SPAM_TO_JUNK=1
MARK_SPAM_AS_READ=0
ACCOUNT_PROVISIONER=FILE
